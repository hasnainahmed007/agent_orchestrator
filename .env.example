# Agent Orchestrator Configuration

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.1

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=user_id_1,user_id_2

# Project Configuration
PROJECT_PATH=C:\\xampp\\htdocs\\Office\\glamdemy_admin_panel
PROJECT_NAME=glamdemy_admin_panel
PROJECT_TYPE=laravel
MAIN_BRANCH=main

# Agent Configuration
AGENT_VERBOSE=true
AGENT_MAX_ITERATIONS=15
AGENT_MEMORY=true

# Safety Settings
REQUIRE_APPROVAL=true
AUTO_MERGE_ON_TESTS_PASS=false
MAX_FILES_PER_TASK=20
ENABLE_ROLLBACK=true

# Cost Control
DAILY_BUDGET_LIMIT=5.0
MAX_TOKENS_PER_REQUEST=4000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/orchestrator.log

# State Management
STATE_FILE=state/orchestrator_state.json
TASKS_FILE=state/tasks.json