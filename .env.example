# Agent Orchestrator Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# OPENAI CONFIGURATION (Required)
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.1

# =============================================================================
# TELEGRAM BOT CONFIGURATION (Optional - only for Telegram mode)
# =============================================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=user_id_1,user_id_2

# =============================================================================
# PROJECT CONFIGURATION (Required)
# =============================================================================
# Path to your project directory (must be a git repository)
PROJECT_PATH=/home/user/projects/my-project
PROJECT_NAME=my-project

# Project type: generic | python | node | laravel
PROJECT_TYPE=generic
MAIN_BRANCH=main

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================
AGENT_VERBOSE=true
AGENT_MAX_ITERATIONS=15
AGENT_MEMORY=true

# =============================================================================
# MULTI-AGENT TEAM SETTINGS
# =============================================================================
DEFAULT_TEAM_CONFIG=default
ENABLE_AUTO_ASSIGN=true
ENABLE_HIERARCHICAL_DELEGATION=true

# =============================================================================
# SAFETY SETTINGS
# =============================================================================
REQUIRE_APPROVAL=true
AUTO_MERGE_ON_TESTS_PASS=false
MAX_FILES_PER_TASK=20
ENABLE_ROLLBACK=true

# =============================================================================
# COST CONTROL
# =============================================================================
DAILY_BUDGET_LIMIT=5.0
MAX_TOKENS_PER_REQUEST=4000

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/orchestrator.log

# =============================================================================
# STATE MANAGEMENT
# =============================================================================
STATE_FILE=state/orchestrator_state.json
TASKS_FILE=state/tasks.json

# =============================================================================
# SKILLS
# =============================================================================
CUSTOM_SKILLS_DIR=skills/custom
